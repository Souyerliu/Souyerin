{
  "name": "astro-blog-shokax",
  "version": "1.3.1",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun astro dev",
    "build:site": "bunx --bun astro build",
    "build:index": "bunx --bun pagefind --site ./dist",
    "build": "bun run build:site && bun run build:index",
    "preview": "bunx --bun astro preview",
    "astro": "bunx --bun astro",
    "check": "bunx --bun astro check --root . && bunx --bun svelte-check",
    "check-links": "lychee ./dist --root-dir ./dist --offline --exclude favicon.svg --cache",
    "lint": "bunx --bun oxlint --type-aware --type-check . --fix",
    "format": "bunx oxfmt .",
    "test": "bun run test:unit",
    "test:unit": "bun test src",
    "e2e:smoke": "bunx playwright test --grep @smoke",
    "e2e:critical": "bunx playwright test --grep @critical",
    "e2e:regression": "bunx playwright test --grep @regression",
    "hyc": "hyc"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/compiler-rs": "^0.1.10",
    "@astrojs/mdx": "5.0.4",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@astrojs/svelte": "8.1.0",
    "@astrojs/ts-plugin": "1.10.7",
    "@ctrl/tinycolor": "^4.2.0",
    "@hyacine/astro": "^0.0.3",
    "@hyacine/cli": "^0.0.3",
    "@hyacine/core": "^0.0.3",
    "@hyacine/helper": "^0.0.3",
    "@hyacine/mouse-firework": "^0.0.3",
    "@hyacine/site-uptime": "^0.0.3",
    "@pagefind/component-ui": "^1.5.2",
    "@playform/inline": "^0.1.4",
    "@unocss/astro": "^66.7.0",
    "@unocss/extractor-svelte": "^66.7.0",
    "@vtbag/element-crossing": "^1.1.0",
    "@waline/client": "^3.15.1",
    "astro": "6.2.1",
    "astro-auto-import": "^0.5.1",
    "echarts": "^6.1.0",
    "es-toolkit": "^1.47.0",
    "i18next": "^26.3.1",
    "katex": "^0.16.47",
    "mouse-firework": "^0.2.0",
    "nyx-player": "^0.1.1",
    "pagefind": "^1.5.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-directive": "^4.0.0",
    "remark-emoji": "^5.0.2",
    "remark-extended-table": "^2.0.3",
    "remark-gfm": "^4.0.1",
    "remark-ins": "^1.2.5",
    "remark-math": "^6.0.0",
    "remark-ruby-directive": "^0.3.0",
    "svelte": "^5.56.1",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.1.0",
    "unocss-inline": "^0.1.4",
    "vite-plugin-es-toolkit": "^1.1.0"
  },
  "devDependencies": {
    "@iconify-json/ri": "^1.2.10",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@shikijs/colorized-brackets": "^4.2.0",
    "@shikijs/transformers": "^4.2.0",
    "@types/bun": "^1.3.14",
    "@unocss/preset-attributify": "^66.7.0",
    "@unocss/preset-icons": "^66.7.0",
    "@unocss/preset-wind4": "^66.7.0",
    "@unocss/reset": "^66.7.0",
    "@unocss/transformer-directives": "^66.7.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.22.1",
    "turbo": "^2.9.16",
    "unocss": "^66.7.0"
  },
  "packageManager": "bun@1.3.12",
  "trustedDependencies": [
    "esbuild",
    "koffi",
    "onnxruntime-node",
    "protobufjs",
    "sharp"
  ]
}
